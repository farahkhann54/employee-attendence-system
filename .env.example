# Firebase web app configuration.
# Copy this file to `.env.local` and replace each value with your Firebase project's keys.
# Get them from: Firebase Console -> Project settings -> Your apps -> Web app -> SDK setup and configuration -> Config.
# These NEXT_PUBLIC_* values are exposed to the browser (Firebase web keys are not secrets),
# but `.env.local` is git-ignored and should not be committed.

NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
